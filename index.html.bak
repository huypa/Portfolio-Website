  </section>

  <script>
    // Hero name typewriter
    (function () {
      const nameEl = document.querySelector('.hero-name');
      if (!nameEl) return;
      const text = nameEl.textContent.trim();
      nameEl.textContent = '';
      setTimeout(() => {
        nameEl.style.opacity = '1';
        let i = 0;
        const t = setInterval(() => {
          nameEl.textContent += text[i++];
          if (i >= text.length) clearInterval(t);
        }, 68);
      }, 400);
    })();

    // Experience keywords scroll reveal
    const expSec = document.getElementById('experience');
    if (expSec) {
      const expKwObs = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting) return;
        entry.target.querySelectorAll('.exp-kw').forEach((kw, i) => {
          setTimeout(() => kw.classList.add('active'), i * 100);
        });
        expKwObs.unobserve(entry.target);
      }, { threshold: 0.05 });
      expKwObs.observe(expSec);
    }

    // Scroll reveal
    const obs = new IntersectionObserver(els => {
      els.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: .08 });
    document.querySelectorAll('.reveal').forEach((el, i) => {
      el.style.transitionDelay = (i % 5) * .08 + 's';
      obs.observe(el);
    });

    // Counter animation for result chips
    function animCount(el, target, suffix = '') {
      let v = 0, dur = 1200, step = 16, inc = target / (dur / step);
      const t = setInterval(() => {
        v = Math.min(v + inc, target);
        el.textContent = Math.round(v) + suffix;
        if (v >= target) clearInterval(t);
      }, step);
    }
    const cObs = new IntersectionObserver(els => {
      els.forEach(e => {
        if (!e.isIntersecting || e.target.dataset.counted) return;
        e.target.dataset.counted = 1;
        const txt = e.target.textContent;
        const m = txt.match(/(\d+)/);
        if (m) animCount(e.target, parseInt(m[1]), txt.replace(/[\d]/g, '').trim());
      });
    }, { threshold: .6 });
    document.querySelectorAll('.hl,.result-chip').forEach(el => cObs.observe(el));

    // Active nav
    const secs = ['projects', 'experience', 'education', 'contact'].map(id => document.getElementById(id)).filter(Boolean);
    const navSpans = document.querySelectorAll('.nav-links span');
    window.addEventListener('scroll', () => {
      let cur = '';
      secs.forEach(s => { if (window.scrollY >= s.offsetTop - 80) cur = s.id; });
      navSpans.forEach(l => l.classList.toggle('nav-active', l.textContent.toLowerCase() === cur));
    }, { passive: true });

    // Scroll to top
    const scrollBtn = document.querySelector('.scroll-top');
    window.addEventListener('scroll', () => {
      scrollBtn.classList.toggle('visible', window.scrollY > 320);
    }, { passive: true });
    scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>

  <!-- Scroll to top button -->
  <button class="scroll-top" aria-label="Back to top">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <polyline points="18 15 12 9 6 15" />
    </svg>
  </button>
</body>

</html>
