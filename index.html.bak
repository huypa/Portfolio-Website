<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anh Huy Phung — Portfolio</title>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --bg: #FFFFFF;
      --bg-alt: #F5F4F0;
      --surface: #FFFFFF;
      --ink: #0F0F0F;
      --muted: #6B6B6B;
      --subtle: #444;
      --border: #E2E2DE;
      --border-strong: #C8C8C2;
      --tag-bg: #EFEFEB;
      --tag-text: #444;
      --green-bg: #E6F4EC;
      --green-border: #52A870;
      --green: #1D5C36;
      --green-dot: #2EAA62;
      --accent: #1A1A1A;
      --footer-bg: #0F0F0F;
      --footer-text: #E8E8E4;
      --footer-muted: #7A7A74;
      --footer-border: #232320;
      --hl-bg: #FFF3C4;
      --hl-text: #7A5200;
    }

    body {
      font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
      background: var(--bg);
      color: var(--ink);
      font-size: 14px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased
    }

    html {
      scroll-behavior: smooth
    }

    /* UTILS */
    .pill {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--tag-bg);
      font-size: 11px;
      color: var(--tag-text);
      font-weight: 500;
      white-space: nowrap;
      border: .5px solid var(--border)
    }

    .pill-hl {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--hl-bg);
      font-size: 11px;
      color: var(--hl-text);
      font-weight: 600;
      white-space: nowrap;
      border: .5px solid #F0D080
    }

    .pill-blue {
      background: #E8F0FE;
      color: #1A56DB;
      border-color: #C3D5F8
    }

    .pill-green {
      background: #E8F8EE;
      color: #166534;
      border-color: #A7DFC0
    }

    .pill-purple {
      background: #F3EEFE;
      color: #5B21B6;
      border-color: #D4BBFC
    }

    .pill-orange {
      background: #FFF4E6;
      color: #92400E;
      border-color: #FCD09A
    }

    .pill-teal {
      background: #E0F7FA;
      color: #00695C;
      border-color: #80CBC4
    }

    .divider {
      height: .5px;
      background: var(--border);
      width: 100%
    }

    .kw {
      background: var(--hl-bg);
      color: var(--hl-text);
      font-weight: 600;
      border-radius: 3px;
      padding: 0 3px
    }

    @keyframes kwFade {
      from {
        background-color: transparent;
        color: var(--subtle);
      }

      to {
        background-color: var(--hl-bg);
        color: var(--hl-text);
      }
    }

    .kw-anim {
      display: inline;
      border-radius: 3px;
      padding: 0 3px;
      font-weight: 600;
      animation: kwFade 0.55s ease forwards;
      animation-fill-mode: both;
    }

    /* EXPERIENCE KEYWORD SCROLL REVEAL */
    .exp-kw {
      border-radius: 3px;
      padding: 0 3px;
      font-weight: 600;
      background: transparent;
      color: var(--subtle);
    }

    .exp-kw.active {
      animation: kwFade 0.55s ease both;
    }

    /* HERO ENTRANCE ANIMATIONS */
    @keyframes heroFadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: none; }
    }

    .hero-anim {
      opacity: 0;
      animation: heroFadeUp 0.5s ease both;
    }

    /* ANIMATIONS */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity .55s ease, transform .55s ease
    }

    .reveal.visible {
      opacity: 1;
      transform: none
    }

    .project-card {
      transition: box-shadow .2s, transform .2s, border-color .2s
    }

    .project-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, .08);
      border-color: var(--border-strong)
    }

    .pill,
    .pill-hl {
      transition: transform .15s;
      cursor: default
    }

    .pill:hover,
    .pill-hl:hover {
      transform: scale(1.06)
    }

    .status-dot {
      animation: pulse 2s infinite
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(46, 170, 98, .5)
      }

      50% {
        box-shadow: 0 0 0 5px rgba(46, 170, 98, 0)
      }
    }

    .hero-title::after {
      content: '|';
      animation: blink 1s step-end infinite;
      font-weight: 300;
      margin-left: 1px
    }

    @keyframes blink {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: 0
      }
    }

    .nav-logo-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      font-family: inherit
    }

    .nav-logo-icon {
      width: 28px;
      height: 28px;
      border-radius: 7px;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    .nav-links span {
      font-size: 13px;
      color: var(--muted);
      cursor: pointer;
      padding: 5px 12px;
      border-radius: 100px;
      border: 0.5px solid transparent;
      transition: color .15s, background .15s, border-color .15s
    }

    .nav-links span:hover {
      color: var(--ink);
      background: var(--tag-bg)
    }

    .nav-links span.nav-active {
      color: var(--ink);
      font-weight: 600;
      background: var(--tag-bg);
      border-color: var(--border)
    }

    /* SCROLL TO TOP */
    .scroll-top {
      position: fixed;
      bottom: 28px;
      right: 28px;
      width: 38px;
      height: 38px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.2s, transform 0.2s;
      z-index: 200
    }

    .scroll-top.visible {
      opacity: 1;
      transform: none
    }

    .scroll-top:hover {
      background: #333
    }

    /* MAX-WIDTH CONTAINER */
    .wrap {
      max-width: 1150px;
      margin: 0 auto;
      padding: 0 44px
    }

    /* NAV */
    nav {
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      height: 60px;
      position: sticky;
      top: 0;
      z-index: 100
    }

    .nav-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 44px;
      height: 100%;
      display: flex;
      align-items: center
    }

    .nav-logo {
      font-size: 14px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -.02em
    }

    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
      margin-left: auto
    }

    .nav-cv {
      margin-left: 20px;
      background: var(--bg-alt);
      color: var(--ink);
      padding: 7px 16px;
      border-radius: 7px;
      font-size: 12.5px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid var(--border-strong);
      cursor: pointer;
      transition: background .15s
    }

    .nav-cv:hover {
      background: var(--border)
    }

    /* HERO */
    .hero {
      background: var(--bg);
      padding: 60px 0 72px
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 5px 13px;
      border-radius: 100px;
      background: var(--green-bg);
      border: 1px solid var(--green-border)
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green-dot)
    }

    .status-badge span {
      font-size: 11.5px;
      font-weight: 500;
      color: var(--green)
    }

    .hero-top {
      display: flex;
      align-items: flex-start;
      gap: 48px;
      margin: 24px 0 0
    }

    .hero-text {
      flex: 1
    }

    .hero-name {
      font-size: 50px;
      font-weight: 700;
      line-height: 1.05;
      color: var(--ink);
      margin-bottom: 10px;
      letter-spacing: -.03em
    }

    .hero-title {
      font-size: 16px;
      color: var(--muted);
      font-weight: 400;
      margin-bottom: 16px;
      letter-spacing: -.01em
    }

    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: var(--tag-bg);
      border: 1px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center
    }

    .avatar svg {
      width: 40px;
      height: 40px
    }

    /* hero bio extended */
    .hero-bio {
      font-size: 13.5px;
      color: var(--subtle);
      line-height: 1.85;
      max-width: 600px
    }

    /* info grid */
    .hero-info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin: 28px 0 0;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden
    }

    .hero-info-col {
      padding: 24px 28px
    }

    .hero-info-col:first-child {
      border-right: 1px solid var(--border)
    }

    .col-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .1em;
      margin-bottom: 14px
    }

    .tech-grid {
      display: flex;
      flex-direction: column;
      gap: 8px
    }

    .tech-row {
      display: grid;
      grid-template-columns: 115px 1fr;
      gap: 8px;
      align-items: flex-start
    }

    .tech-cat {
      font-size: 10px;
      font-weight: 600;
      color: var(--muted);
      padding-top: 4px;
      letter-spacing: .03em
    }

    .tech-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 4px
    }

    /* social buttons — grey like bg-alt */
    .social-row {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-top: 24px;
      flex-wrap: wrap
    }

    .btn-social {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 16px;
      background: var(--bg-alt);
      color: var(--ink);
      border-radius: 8px;
      font-size: 12.5px;
      font-weight: 500;
      border: 1px solid var(--border-strong);
      cursor: pointer;
      font-family: inherit;
      white-space: nowrap;
      text-decoration: none;
      transition: background .15s, border-color .15s
    }

    .btn-social:hover {
      background: var(--border);
      border-color: var(--border-strong)
    }

    .btn-social svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0
    }

    /* PROJECTS */
    .projects-section {
      background: var(--bg-alt);
      padding: 64px 0
    }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 20px
    }

    .section-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -.03em
    }

    .section-count {
      font-size: 12px;
      color: var(--muted)
    }

    .search-bar {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 10px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 14px
    }

    .search-bar span {
      font-size: 12.5px;
      color: #BBBAB5
    }

    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 24px
    }

    .filter-active {
      background: var(--accent);
      color: #fff;
      padding: 5px 14px;
      border-radius: 100px;
      font-size: 11.5px;
      font-weight: 500;
      cursor: pointer
    }

    .filter-pill {
      background: var(--surface);
      color: var(--muted);
      padding: 5px 14px;
      border-radius: 100px;
      font-size: 11.5px;
      font-weight: 500;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: border-color .15s, color .15s
    }

    .filter-pill:hover {
      color: var(--ink);
      border-color: var(--border-strong)
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px
    }

    .project-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 22px;
      display: flex;
      flex-direction: column
    }

    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px
    }

    .project-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.4;
      flex: 1;
      letter-spacing: -.01em
    }

    .project-year {
      font-size: 11px;
      color: var(--muted);
      white-space: nowrap;
      margin-left: 8px
    }

    .project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-bottom: 10px
    }

    .project-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
      flex: 1;
      padding-left: 4px
    }

    .project-bullets li {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.7;
      padding-left: 18px;
      position: relative
    }

    .project-bullets li::before {
      content: '•';
      position: absolute;
      left: 0;
      color: var(--border-strong);
      font-size: 13px;
      line-height: 1.55
    }

    .project-results {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-bottom: 12px
    }

    .result-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 9px;
      border-radius: 6px;
      background: var(--hl-bg);
      border: .5px solid #F0D080;
      font-size: 10.5px;
      font-weight: 600;
      color: var(--hl-text)
    }

    .result-chip svg {
      width: 10px;
      height: 10px;
      flex-shrink: 0
    }

    .project-footer {
      margin-top: auto;
      padding-top: 10px;
      border-top: .5px solid var(--border);
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11.5px;
      color: var(--muted);
      font-weight: 500
    }

    .project-footer svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0
    }

    .project-footer a {
      color: inherit;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 5px
    }

    .project-footer a:hover {
      color: var(--ink)
    }

    .project-card:hover .project-footer {
      color: var(--subtle)
    }

    /* EXPERIENCE */
    .experience-section {
      background: var(--bg);
      padding: 64px 0
    }

    .exp-row {
      padding: 28px 0
    }

    .exp-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 5px
    }

    .exp-role {
      font-size: 15px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -.02em;
      line-height: 1.35
    }

    .exp-date-badge {
      font-size: 11.5px;
      color: var(--muted);
      white-space: nowrap;
      padding: 3px 10px;
      background: var(--tag-bg);
      border-radius: 100px;
      border: .5px solid var(--border);
      flex-shrink: 0;
      margin-top: 2px
    }

    .exp-company {
      font-size: 12.5px;
      color: var(--muted);
      margin-bottom: 12px
    }

    .exp-company-name {
      font-weight: 600;
      color: var(--subtle)
    }

    .exp-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-left: 4px
    }

    .exp-bullets li {
      font-size: 13px;
      color: var(--subtle);
      line-height: 1.75;
      padding-left: 18px;
      position: relative
    }

    .exp-bullets li::before {
      content: '•';
      position: absolute;
      left: 0;
      color: var(--border-strong);
      font-size: 13px;
      line-height: 1.6
    }

    .hl {
      font-weight: 600;
      color: var(--ink)
    }

    /* EDUCATION */
    .education-section {
      background: var(--bg-alt);
      padding: 64px 0
    }

    .edu-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 22px
    }

    .edu-meta {
      font-size: 13px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 2px
    }

    .edu-sub {
      font-size: 11.5px;
      color: var(--muted);
      margin-bottom: 12px
    }

    .edu-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 10px;
      padding-left: 4px
    }

    .edu-bullets li {
      font-size: 12.5px;
      color: var(--subtle);
      line-height: 1.65;
      padding-left: 18px;
      position: relative
    }

    .edu-bullets li::before {
      content: '•';
      position: absolute;
      left: 0;
      color: var(--border-strong);
      font-size: 13px;
      line-height: 1.55
    }

    /* CONTACT */
    .contact-section {
      background: var(--footer-bg);
      padding: 64px 0
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px
    }

    .contact-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--footer-text);
      margin-bottom: 10px;
      letter-spacing: -.03em
    }

    .contact-desc {
      font-size: 13px;
      color: var(--footer-muted);
      line-height: 1.78;
      margin-bottom: 24px
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--footer-text);
      margin-bottom: 10px;
      text-decoration: none
    }

    .contact-link svg {
      width: 14px;
      height: 14px;
      color: var(--footer-muted);
      flex-shrink: 0
    }

    .btn-footer {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 10px 18px;
      border-radius: 8px;
      font-size: 12.5px;
      font-weight: 500;
      border: 1px solid var(--footer-border);
      cursor: pointer;
      font-family: inherit;
      color: var(--footer-text);
      background: transparent;
      margin-bottom: 8px;
      transition: border-color .15s;
      text-decoration: none
    }

    .btn-footer:hover {
      border-color: #555
    }

    .btn-footer-light {
      background: #2A2A2A;
      color: var(--footer-text);
      border-color: #3A3A3A
    }

    .btn-footer-light:hover {
      background: #333
    }

    .footer-bar {
      margin-top: 56px;
      padding-top: 20px;
      border-top: .5px solid var(--footer-border);
      display: flex;
      justify-content: space-between
    }

    .footer-bar span {
      font-size: 11.5px;
      color: var(--footer-muted)
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <button class="nav-logo-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        <div class="nav-logo-icon">
          <svg width="14" height="14" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <polyline points="16 18 22 12 16 6" />
            <polyline points="8 6 2 12 8 18" />
          </svg>
        </div>
        <span class="nav-logo">Anh Huy Phung</span>
      </button>
      <div class="nav-links">
        <span onclick="document.getElementById('projects').scrollIntoView({behavior:'smooth'})">Projects</span>
        <span onclick="document.getElementById('experience').scrollIntoView({behavior:'smooth'})">Experience</span>
        <span onclick="document.getElementById('education').scrollIntoView({behavior:'smooth'})">Education</span>
        <span onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Contact</span>
        <button class="nav-cv">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 15V3m0 12-4-4m4 4 4-4M2 17l.621 2.485A2 2 0 004.561 21h14.878a2 2 0 001.94-1.515L22 17" />
          </svg>
          Download CV
        </button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">

      <!-- Status badge -->
      <div class="hero-anim" style="margin-bottom:24px;animation-delay:0.05s">
        <div class="status-badge">
          <div class="status-dot"></div><span>Open to opportunities</span>
        </div>
      </div>

      <!-- Avatar + Name row -->
      <div style="display:flex;align-items:center;gap:18px;margin-bottom:16px">
        <div class="avatar hero-anim" style="animation-delay:0.2s">
          <img src="profile.jpeg" alt="Anh Huy Phung"
            style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
        </div>
        <div>
